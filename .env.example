OCR_PROVIDER=gemini

# Carpeta de imagenes a analizar
INPUT_DIR=input

# Archivo JSON de salida
OUTPUT_FILE=output/results.json

# 0 = sin limite
MAX_IMAGES=0

# Gemini
GEMINI_API_KEY=pegatuapikey
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (opcional si OCR_PROVIDER=openai)
OPENAI_API_KEY=pegatuapikey
OPENAI_API_URL=https://api.openai.com/v1/responses
OPENAI_MODEL=gpt-4.1-mini

# Banco (opcional si OCR_PROVIDER=banco)
BANCO_API_KEY=pegatuapikey
BANCO_API_URL=https://tu-banco-api.com/v1/responses
BANCO_MODEL=banco-ocr-v1
